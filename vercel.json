{
  "version": 2,
  "crons": [
    { "path": "/api/cron", "schedule": "0 */2 * * *" }
  ],
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/tours.js", "use": "@vercel/node", "config": { "maxDuration": 15 } },
    { "src": "api/cron.js",  "use": "@vercel/node", "config": { "maxDuration": 60 } }
  ],
  "routes": [
    { "src": "/api/tours", "dest": "/api/tours.js" },
    { "src": "/api/cron",  "dest": "/api/cron.js"  },
    { "src": "/style.css", "dest": "/public/style.css" },
    { "src": "/app.js",    "dest": "/public/app.js" },
    { "src": "/",          "dest": "/public/index.html" }
  ]
}
